{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "strict": false,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".", // 기준 경로 설정
    "paths": {
      "@/*": ["src/*"] // "@/"로 시작하면 "src/" 폴더를 봐라!
    }
  }
}